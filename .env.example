# ============================================================
# National Land Data System — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
# Your deployed URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://nationallanddata.com

# ── Stripe ──────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret — get after running: stripe listen --forward-to localhost:3000/api/webhook
# Or from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Email (any one of these) ─────────────────────────────────
# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Or SendGrid
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=deals@nationallanddata.com

# Or Loops: https://loops.so/api
LOOPS_API_KEY=...

# ── Cron ─────────────────────────────────────────────────────
# Secret for cron endpoint — any random string
CRON_SECRET=your-random-secret-here

# Dashboard secret for /api/system-status
DASHBOARD_SECRET=your-dashboard-secret-here

# ── Optional ─────────────────────────────────────────────────
# Analytics (if using Segment or custom)
# SEGMENT_WRITE_KEY=...

# ── Vercel Deployment ───────────────────────────────────────
# Set via: vercel env add VARIABLE_NAME
# Or in Vercel Dashboard → Settings → Environment Variables
